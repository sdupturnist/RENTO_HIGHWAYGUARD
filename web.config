<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- Proxy everything to Next.js using the raw request URI.
             {REQUEST_URI} preserves the exact URL including characters like
             (protected) and (public) in Next.js chunk paths without any
             regex back-reference substitution that could mangle them. -->
        <rule name="NextJS Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3011{REQUEST_URI}" appendQueryString="false" />
        </rule>
      </rules>
    </rewrite>

    <!-- Disable IIS caching — Next.js manages its own cache headers -->
    <caching enabled="false" enableKernelCache="false" />

  </system.webServer>
</configuration>
